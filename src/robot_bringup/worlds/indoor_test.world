          <material>
            <ambient>0.4 0.45 0.5 1</ambient>
            <diffuse>0.4 0.45 0.5 1</diffuse>
          </material>
        </visual>
      </link>
    </model>

    <model name="left_obstacle">
      <static>true</static>
      <pose>-1.6 1.8 0.3 0 0 0</pose>
      <link name="link">
        <collision name="collision">
          <geometry>
            <cylinder>
              <radius>0.25</radius>
              <length>0.6</length>
